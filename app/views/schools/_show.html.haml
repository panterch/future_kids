= show_for @school do |show|
  = show.attribute :name
  = show.attribute :school_kind
  = show.attribute :street
  = show.attribute :city
  = show.attribute :homepage do
    -if @school.homepage.present?
      %a{:href => @school.homepage}= @school.homepage
  = show.attribute :social
  = show.attribute :district
  = show.attribute :term
  = show.attribute :note
  - if current_user.is_a?(Admin)
    = show.attribute :inactive
    - if @school.inactive?
      = show.attribute :inactive_at

- if current_user.is_a?(Admin) && !@school.inactive?
  = button_to 'Inaktiv setzen', inactivate_school_path(@school),
      method: :put, class: 'btn btn-danger btn-xs',
      data: { confirm: 'Schule wirklich inaktivieren?' }

= render 'associations'
