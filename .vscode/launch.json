{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "ruby_lsp",
      "name": "Rails server",
      "request": "launch",
      "program": "${workspaceFolder}/bin/rails",
      "args": ["server"]
    },
    {
      "type": "ruby_lsp",
      "name": "RSpec - current file",
      "request": "launch",
      "program": "${workspaceFolder}/bin/rspec",
      "args": ["${relativeFile}"]
    },
    {
      "type": "ruby_lsp",
      "name": "RSpec - all",
      "request": "launch",
      "program": "${workspaceFolder}/bin/rspec"
    }
  ]
}
